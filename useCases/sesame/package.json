{
  "name": "sesame",
  "version": "1.0.0",
  "private": true,
  "description": "SESAME simulation workspace",
  "scripts": {
    "start": "run-p start:api start:client",
    "start:api": "cd api/springBoot-simulator && ./mvnw spring-boot:run",
    "start:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "test:api": "cd api/springBoot-simulator && ./mvnw test",
    "package:api": "cd api/springBoot-simulator && ./mvnw -DskipTests package"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
